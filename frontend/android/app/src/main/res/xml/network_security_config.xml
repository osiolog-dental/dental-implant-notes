<?xml version="1.0" encoding="utf-8"?>
<!--
  Dev-only network security config.
  Allows cleartext HTTP to the Android emulator host (10.0.2.2) and localhost.
  Production builds use HTTPS; this file can be overridden per build variant.
-->
<network-security-config>
    <!-- Allow all cleartext for local dev targets -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
    </domain-config>
</network-security-config>
