# DentalHub — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env to git.

# ─── PostgreSQL ────────────────────────────────────────────────────────────────
# Full connection string for the managed PostgreSQL instance (AWS Lightsail).
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dentalhub

# ─── Firebase Auth ─────────────────────────────────────────────────────────────
# Found in Firebase Console → Project Settings → General
FIREBASE_PROJECT_ID=your-firebase-project-id

# Absolute path to the Firebase service account key JSON file on the server.
# Download from Firebase Console → Project Settings → Service Accounts.
# Keep this file outside the repo root and never commit it.
FIREBASE_SERVICE_ACCOUNT_JSON=/path/to/firebase-service-account.json

# ─── AWS ───────────────────────────────────────────────────────────────────────
# IAM user credentials with s3:PutObject, s3:GetObject, s3:DeleteObject on the bucket.
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# S3 bucket for clinical images (private, no public access).
AWS_S3_BUCKET_NAME=dentalhub-clinical-images

# AWS region — default is ap-south-1 (Mumbai) for Lightsail + SES proximity.
AWS_REGION=ap-south-1

# ─── Application ───────────────────────────────────────────────────────────────
# The public URL of the React frontend (used for CORS and email links).
FRONTEND_URL=http://localhost:3000

# Set to "development" locally, "production" on the server.
# Controls debug logging, CORS strictness, and error detail in responses.
ENVIRONMENT=development

# ─── PROTOTYPE ONLY — remove after migration to PostgreSQL + Firebase Auth ─────
MONGO_URL=mongodb://localhost:27017
DB_NAME=dental_implant_db
JWT_SECRET=your-jwt-secret-here
